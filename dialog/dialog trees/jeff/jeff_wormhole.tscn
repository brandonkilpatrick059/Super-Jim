[node name="wormhole9" parent="." node_paths=PackedStringArray("option_branches") instance=ExtResource("2_bj1t4")]
position = Vector2(-1560, 3746)
speaker_text = Array[String](["Since I got stuck in these sewers, I've been studying..."])
