[node name="wormhole4" parent="." node_paths=PackedStringArray("option_branches") instance=ExtResource("2_bj1t4")]
position = Vector2(-1479, 1489)
speaker_text = Array[String](["I haven't heard from my brother, Sebastian, since these sewers were built."])
speaker_portrait = null
option_branches = [NodePath("../wormhole5")]
voice = "worm_voice"

[node name="wormhole5" parent="." node_paths=PackedStringArray("option_branches") instance=ExtResource("2_bj1t4")]
position = Vector2(-1497, 1891)
speaker_text = Array[String](["He's down here somewhere, but I don't know where."])
speaker_portrait = null
option_branches = [NodePath("../wormhole6")]
voice = "worm_voice"

[node name="wormhole6" parent="." node_paths=PackedStringArray("option_branches") instance=ExtResource("2_bj1t4")]
position = Vector2(-1507, 2255)
speaker_text = Array[String](["Do you think you could find him and check in on him?"])
speaker_portrait = null
option_branches = [NodePath("../wormhole7")]
voice = "worm_voice"

[node name="wormhole7" parent="." node_paths=PackedStringArray("option_branches") instance=ExtResource("2_bj1t4")]
position = Vector2(-1552, 2662)
speaker_text = Array[String](["I've asked Gary, but he's scared to go poking around down here..."])
