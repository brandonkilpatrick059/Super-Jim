[layer_names]

2d_physics/layer_1="player"
2d_physics/layer_2="red mobs"
2d_physics/layer_3="npcs"
2d_physics/layer_4="dynamic props"
2d_physics/layer_5="static walls"
2d_physics/layer_6="red bullets"
2d_physics/layer_7="blu mobs"
2d_physics/layer_8="blu bullets"
2d_physics/layer_9="spark"
2d_physics/layer_10="red mobs vision"
2d_physics/layer_11="blu mobs vision"
2d_physics/layer_12="reactive props"
2d_physics/layer_13="prop wall"
2d_physics/layer_14="actor wall"
2d_physics/layer_15="bottomless pit"
2d_physics/layer_16="player_wall"
2d_render/snap/snap_2d_transforms_to_pixel=false
2d_render/snap/snap_2d_vertices_to_pixel=false

[navigation]

2d/default_edge_connection_margin=4.0

[physics]

common/max_physics_steps_per_frame=4
2d/default_gravity=0.0
2d/default_gravity_vector=Vector2(0, 0)
common/enable_object_picking=false

[rendering]

textures/canvas_textures/default_texture_filter=0
driver/threads/thread_model=2
textures/default_filters/anisotropic_filtering_level=1
anti_aliasing/screen_space_roughness_limiter/enabled=false
